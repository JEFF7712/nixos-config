#!/usr/bin/env bash
set -euo pipefail

PROFILES_DIR="$HOME/.config/desktop-profiles"
ACTIVE_FILE="$PROFILES_DIR/active"
ACTIVE_LINK="$PROFILES_DIR/active-niri-overrides.kdl"
REPO="$HOME/nixos/modules/home-manager"

list_profiles() {
  local current=""
  [ -f "$ACTIVE_FILE" ] && current=$(cat "$ACTIVE_FILE")
  echo "Available profiles:"
  for dir in "$PROFILES_DIR"/*/; do
    [ -d "$dir" ] || continue
    name=$(basename "$dir")
    if [ "$name" = "$current" ]; then
      echo "  * $name (active)"
    else
      echo "    $name"
    fi
  done
}

if [ $# -eq 0 ]; then
  list_profiles
  exit 0
fi

TARGET="$1"
TARGET_DIR="$PROFILES_DIR/$TARGET"

if [ ! -d "$TARGET_DIR" ]; then
  echo "Error: profile '$TARGET' not found." >&2
  list_profiles
  exit 1
fi

# Read currently running bar from active profile
CURRENT_BAR="noctalia"
if [ -f "$ACTIVE_FILE" ]; then
  CURRENT=$(cat "$ACTIVE_FILE")
  if [ -f "$PROFILES_DIR/$CURRENT/meta.json" ]; then
    CURRENT_BAR=$(jq -r '.bar' "$PROFILES_DIR/$CURRENT/meta.json")
  fi
fi

TARGET_BAR=$(jq -r '.bar' "$TARGET_DIR/meta.json")
TARGET_CURSOR=$(jq -r '.cursor' "$TARGET_DIR/meta.json")
TARGET_CURSOR_SIZE=$(jq -r '.cursorSize' "$TARGET_DIR/meta.json")
TARGET_WALLPAPER_DIR=$(cat "$TARGET_DIR/wallpaper-dir" 2>/dev/null || echo "")

echo "Switching to profile: $TARGET"

# 1. Stop current bar
if [ "$CURRENT_BAR" = "noctalia" ]; then
  echo "  Stopping noctalia-shell..."
  systemctl --user stop noctalia-shell 2>/dev/null || true
elif [ "$CURRENT_BAR" = "waybar" ]; then
  echo "  Stopping waybar..."
  pkill -f waybar 2>/dev/null || true
  # Wait up to 2s for waybar to fully exit before proceeding
  for _ in $(seq 1 20); do
    pgrep -f waybar >/dev/null 2>&1 || break
    sleep 0.1
  done
  # Clean up waybar configs so a stale Nord config doesn't persist
  rm -f "$HOME/.config/waybar/config.jsonc" "$HOME/.config/waybar/style.css" 2>/dev/null || true
  # Stop mako (nord uses mako; noctalia manages its own notifications)
  pkill -x mako 2>/dev/null || true
fi

# 2. Copy color files (skip for noctalia — it manages its own colors)
if [ "$TARGET" != "noctalia" ]; then
  echo "  Applying color files..."
  [ -s "$TARGET_DIR/gtk-3.0.css" ]       && cp "$TARGET_DIR/gtk-3.0.css"       "$REPO/configs/gtk-3.0/noctalia.css"
  [ -s "$TARGET_DIR/gtk-4.0.css" ]       && cp "$TARGET_DIR/gtk-4.0.css"       "$REPO/configs/gtk-4.0/noctalia.css"
  [ -s "$TARGET_DIR/qt6ct.conf" ]        && cp "$TARGET_DIR/qt6ct.conf"        "$REPO/configs/qt6ct/colors/noctalia.conf"
  # Kitty: configs/kitty is an out-of-store symlink to the repo, so writing
  # to the repo path is immediately reflected at ~/.config/kitty/colors.conf
  [ -s "$TARGET_DIR/kitty-colors.conf" ] && cp "$TARGET_DIR/kitty-colors.conf" "$REPO/configs/kitty/colors.conf"
  [ -s "$TARGET_DIR/rofi-theme.rasi" ]   && cp "$TARGET_DIR/rofi-theme.rasi"   "$REPO/configs/rofi/profile-switcher.rasi"
  # Firefox: configs/firefox/chrome is now an out-of-store symlink so writing
  # to the repo path is immediately reflected in the browser (reload userChrome).
  FF_GLOBALS="$REPO/configs/firefox/chrome/DownToneUI/_globals.css"
  case "$TARGET" in
    nord)
      FF_MAIN="46, 52, 64"; FF_SEC="59, 66, 82"
      FF_ACCENT="136, 192, 208"; FF_TEXT="216, 222, 233"
      FF_ACCENT_HSL="hsl(193, 43%, 78%)" ;;
    catppuccin)
      FF_MAIN="30, 30, 46"; FF_SEC="24, 24, 37"
      FF_ACCENT="203, 166, 247"; FF_TEXT="205, 214, 244"
      FF_ACCENT_HSL="hsl(267, 84%, 81%)" ;;
    gruvbox)
      FF_MAIN="40, 40, 40"; FF_SEC="60, 56, 54"
      FF_ACCENT="250, 189, 47"; FF_TEXT="235, 219, 178"
      FF_ACCENT_HSL="hsl(43, 95%, 58%)" ;;
  esac
  cat > "$FF_GLOBALS" << EOF
/* ============================================================================
 * Shared: should be copied to Sidebery settings > Styles editor
 * ========================================================================= */

* {
  --dtui-theme-color-scheme: dark;
  --dtui-theme-main-color: $FF_MAIN;
  --dtui-theme-secondary-color: $FF_SEC;
  --dtui-theme-accent-color: $FF_ACCENT;
  --dtui-theme-text-color: $FF_TEXT;

  --dtui-theme-accent-low-alpha: 0.5;
  --dtui-theme-accent-mid-alpha: 0.75;
  --dtui-theme-accent-high-contrast: $FF_ACCENT_HSL;
  --dtui-theme-text-low-alpha: 0.5;
  --dtui-theme-text-mid-alpha: 0.75;

  --dtui-theme-separator-color: rgba(var(--dtui-theme-text-color), 0.1);
  --dtui-theme-border-color: rgba(var(--dtui-theme-text-color), 0);
  --dtui-theme-border-width: 2px;
  --dtui-theme-border-radius: 6px;

  --dtui-sidebar-hover-debounce: 0ms;
  --dtui-sidebar-animation-speed: 300ms;
}

/* ============================================================================
 * Others
 * ========================================================================= */

* {
  --dtui-theme-shadow-margin: 6px;
  --dtui-theme-shadow: 0px 0px var(--dtui-theme-shadow-margin) hsla(0, 0%, 0%, 0.4);

  --dtui-sidebar-collapsed-width: 34px;
  --dtui-sidebar-no-extend-width: 34px;
  --dtui-sidebar-extended-width: 270px;
  --dtui-bookmarks-hover-debounce: 200ms;
  --dtui-bookmarks-animation-speed: 200ms;
  --dtui-menu-animation-speed: 250ms;
  --dtui-window-animation-speed: 350ms;
  --dtui-urlbar-animation-speed: 300ms;

  --dtui-bookmarks-inner-height: 20px;
}
EOF
  [ -s "$TARGET_DIR/fish-theme.fish" ]   && cp "$TARGET_DIR/fish-theme.fish"   "$HOME/.config/fish/conf.d/matugen_theme.fish"
  [ -s "$TARGET_DIR/starship.toml" ]     && cp "$TARGET_DIR/starship.toml"     "$HOME/.config/starship_matugen.toml"
  # Generate pywal cache and push colors to Firefox via pywalfox
  if command -v wal >/dev/null 2>&1; then
    echo "  Generating pywal colors..."
    case "$TARGET" in
      gruvbox) WAL_THEME="base16-gruvbox-dark-hard" ;;
      *)       WAL_THEME="base16-nord" ;;
    esac
    wal --theme "$WAL_THEME" -q 2>/dev/null || true
    command -v pywalfox >/dev/null 2>&1 && pywalfox update 2>/dev/null || true
  fi
fi

# 3. Update niri overrides symlink atomically (tmp + mv avoids missing-file window)
echo "  Updating niri overrides..."
TMPLINK=$(mktemp -u "$PROFILES_DIR/.active-niri-overrides.XXXXXX")
ln -s "$TARGET_DIR/niri-overrides.kdl" "$TMPLINK"
mv "$TMPLINK" "$ACTIVE_LINK"

# 4. Reload niri (picks up new cursor, borders, shadow, tab-indicator, opacity)
niri msg action reload-config 2>/dev/null || true

# 5. Apply cursor to GTK/XDG layer
echo "  Applying cursor..."
gsettings set org.gnome.desktop.interface cursor-theme "$TARGET_CURSOR"   2>/dev/null || true
gsettings set org.gnome.desktop.interface cursor-size  "$TARGET_CURSOR_SIZE" 2>/dev/null || true

# 6. Record active profile NOW so ExecCondition sees the right profile when starting noctalia-shell
echo "$TARGET" > "$ACTIVE_FILE"

# 6b. Start new bar + manage swww (noctalia has its own wallpaper engine; waybar needs swww)
if [ "$TARGET_BAR" = "noctalia" ]; then
  echo "  Starting noctalia-shell..."
  systemctl --user stop swww 2>/dev/null || true  # noctalia owns the wallpaper layer
  systemctl --user start noctalia-shell 2>/dev/null || true
  sleep 1  # allow noctalia to come up before IPC call
elif [ "$TARGET_BAR" = "waybar" ]; then
  echo "  Starting waybar..."
  systemctl --user start swww 2>/dev/null || true  # swww needed for static wallpapers
  if [ -f "$TARGET_DIR/waybar-config.jsonc" ]; then
    mkdir -p "$HOME/.config/waybar"
    cp "$TARGET_DIR/waybar-config.jsonc" "$HOME/.config/waybar/config.jsonc" 2>/dev/null || true
    cp "$TARGET_DIR/waybar-style.css"    "$HOME/.config/waybar/style.css"   2>/dev/null || true
  fi
  waybar 2>/dev/null &
  disown
  # Start mako for nord notifications
  mako 2>/dev/null &
  disown
fi

# 7. Set wallpaper (after bar start so noctalia IPC is available)
echo "  Setting wallpaper..."
if [ "$TARGET" = "noctalia" ]; then
  # wallpaper random requires a screen argument; call it for each connected output
  while IFS= read -r screen; do
    noctalia-shell ipc --any-display call wallpaper random "$screen" 2>/dev/null || true
  done < <(niri msg outputs 2>/dev/null | grep '^Output ' | sed 's/^Output ".*" (\(.*\))/\1/')
  # Wait for noctalia to generate colors.json, then apply user templates (including kitty)
  (
    sleep 4
    NOCSHELL=$(readlink -f "$(which noctalia-shell)")
    NOCBASE="${NOCSHELL%/bin/noctalia-shell}"
    SCRIPTS="$NOCBASE/share/noctalia-shell/Scripts/python/src/theming"
    if [ -f "$SCRIPTS/template-processor.py" ] && [ -f "$HOME/.config/noctalia/colors.json" ]; then
      cd "$SCRIPTS" && python3 template-processor.py \
        --scheme "$HOME/.config/noctalia/colors.json" \
        --config "$HOME/.config/noctalia/user-templates.toml" \
        --mode dark 2>/dev/null || true
    fi
  ) &
elif [ -d "$TARGET_WALLPAPER_DIR" ]; then
  WALLPAPER=$(find "$TARGET_WALLPAPER_DIR" -maxdepth 1 \
    -type f \( -name "*.jpg" -o -name "*.jpeg" -o -name "*.png" -o -name "*.webp" \) \
    | shuf -n 1)
  if [ -n "$WALLPAPER" ]; then
    swww img "$WALLPAPER" --transition-type fade --transition-duration 1 2>/dev/null || true
  else
    echo "  Warning: no wallpaper images found in $TARGET_WALLPAPER_DIR"
  fi
  # Update waypaper config so its folder picker opens the right directory
  WAYPAPER_CFG="$HOME/.config/waypaper/config.ini"
  if [ -f "$WAYPAPER_CFG" ] && [ -n "$TARGET_WALLPAPER_DIR" ]; then
    WAYPAPER_FOLDER="${TARGET_WALLPAPER_DIR/#$HOME/\~}"
    sed -i "s|^folder = .*|folder = $WAYPAPER_FOLDER|" "$WAYPAPER_CFG"
    [ -n "$WALLPAPER" ] && sed -i "s|^wallpaper = .*|wallpaper = ${WALLPAPER/#$HOME/\~}|" "$WAYPAPER_CFG"
  fi
fi

# 8. Signal kitty to reload colors (noctalia handles this via template-processor post_hook)
if [ "$TARGET" != "noctalia" ]; then
  pkill -USR1 -x kitty 2>/dev/null || true
fi

# 9. Update Zed theme + icon theme
ZED_SETTINGS="$HOME/.config/zed/settings.json"
if [ -f "$ZED_SETTINGS" ]; then
  case "$TARGET" in
    catppuccin) ZED_THEME="Catppuccin Mocha (Blur)" ; ZED_ICON="Catppuccin Mocha" ;;
    nord)       ZED_THEME="Nord Dark"         ; ZED_ICON="Zed (Default)" ;;
    noctalia)   ZED_THEME="Ayu Dark"          ; ZED_ICON="Material Icon Theme" ;;
    gruvbox)    ZED_THEME="Gruvbox Dark"      ; ZED_ICON="Zed (Default)" ;;
    *)          ZED_THEME=""                  ; ZED_ICON="" ;;
  esac
  if [ -n "$ZED_THEME" ]; then
    sed -i "/\"theme\"/,/}/ s/\"dark\": \".*\"/\"dark\": \"$ZED_THEME\"/" "$ZED_SETTINGS"
  fi
  if [ -n "$ZED_ICON" ]; then
    sed -i "/\"icon_theme\"/,/}/ s/\"dark\": \".*\"/\"dark\": \"$ZED_ICON\"/" "$ZED_SETTINGS"
  fi
fi

# 10. Notify
notify-send "Desktop Profile" "Switched to $TARGET" 2>/dev/null || true
echo "Done. Profile '$TARGET' is now active."
