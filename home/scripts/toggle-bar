#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

ACTIVE=$(cat "$ACTIVE_FILE" 2>/dev/null || echo "")
[ -n "$ACTIVE" ] || exit 0

BAR=$(profile_bar "$ACTIVE")
QUICKSHELL_TOPBAR="$REPO_HOME/configs/quickshell-clean/shell.qml"

toggle_quickshell() {
  if pgrep -f "quickshell.*quickshell-clean/shell.qml" >/dev/null 2>&1; then
    pkill -f "quickshell.*quickshell-clean/shell.qml" 2>/dev/null || true
  else
    quickshell -p "$QUICKSHELL_TOPBAR" >/dev/null 2>&1 &
    disown
  fi
}

toggle_waybar() {
  if pgrep -f waybar >/dev/null 2>&1; then
    pkill -f waybar 2>/dev/null || true
  else
    waybar >/dev/null 2>&1 &
    disown
  fi
}

case "$BAR" in
  noctalia)
    noctalia-shell ipc --any-display call bar toggle
    ;;
  quickshell | clean)
    toggle_quickshell
    ;;
  waybar)
    toggle_waybar
    ;;
esac
