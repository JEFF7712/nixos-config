#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

PROFILE=$(cat "$PROFILES_DIR/active" 2>/dev/null || echo "noctalia")
VARIANT=$(cat "$PROFILES_DIR/active-variant" 2>/dev/null || echo "dark")

if [ "$PROFILE" = "noctalia" ]; then
  stop_video_wallpaper
  while IFS= read -r screen; do
    noctalia-shell ipc --any-display call wallpaper random "$screen" 2>/dev/null || true
  done < <(niri msg outputs 2>/dev/null | grep '^Output ' | sed 's/^Output ".*" (\(.*\))/\1/')
  exit 0
fi

TARGET_DIR="$PROFILES_DIR/$PROFILE"
profile_manifest_validate "$PROFILE" "$VARIANT"
WALLPAPER_DIR=$(profile_manifest_wallpaper_dir "$PROFILE" "$VARIANT")

[ -d "$WALLPAPER_DIR" ] || exit 0

WALLPAPER=$(pick_random_wallpaper "$WALLPAPER_DIR")

[ -n "$WALLPAPER" ] || exit 0

set_wallpaper "$WALLPAPER"

WAYPAPER_CFG="$HOME/.config/waypaper/config.ini"
if [ -f "$WAYPAPER_CFG" ]; then
  ensure_waypaper_post_command "$WAYPAPER_CFG"
  sed -i "s|^wallpaper = .*|wallpaper = ${WALLPAPER/#$HOME/\~}|" "$WAYPAPER_CFG"
fi
