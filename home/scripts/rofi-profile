#!/usr/bin/env bash
# Profile switcher using rofi dmenu mode.
# Rofi closes immediately after selection, then switch-profile runs in background.

PROFILES_DIR="$HOME/.config/desktop-profiles"
PREVIEW_DIR="$HOME/nixos/home/assets/previews"
ACTIVE=$(cat "$PROFILES_DIR/active" 2>/dev/null || echo "")
THEME="$HOME/nixos/home/configs/rofi/profile-switcher.rasi"

# Build the entry list and remember which row is the active profile so we can
# pass it to rofi as an "urgent" row for visual highlighting.
entries=""
active_index=""
index=0
for dir in "$PROFILES_DIR"/*/; do
  [ -d "$dir" ] || continue
  name=$(basename "$dir")
  preview="$PREVIEW_DIR/$name.png"
  if [ -f "$preview" ]; then
    entries+=$(printf "%s\0icon\x1f%s\n" "$name" "$preview")
  else
    entries+="$name"
  fi
  entries+=$'\n'
  [ "$name" = "$ACTIVE" ] && active_index="$index"
  index=$((index + 1))
done

urgent_arg=()
[ -n "$active_index" ] && urgent_arg=(-u "$active_index")

selected=$(
  printf "%s" "$entries" | rofi \
    -dmenu \
    -show-icons \
    -icon-theme Adwaita \
    "${urgent_arg[@]}" \
    -theme "$THEME"
)

[ -z "$selected" ] && exit 0

switch-profile "$selected" >/dev/null 2>&1 </dev/null &
disown
