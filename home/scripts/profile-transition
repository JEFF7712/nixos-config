#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/profile-common"

usage() {
  echo "Usage: profile-transition switch NAME | variant dark|light|toggle | reapply | startup [NAME]" >&2
  exit 2
}

write_atomic() {
  local path="$1" value="$2" tmp
  mkdir -p "$(dirname "$path")"
  tmp=$(mktemp "${path}.XXXXXX")
  printf '%s\n' "$value" > "$tmp"
  mv "$tmp" "$path"
}

link_atomic() {
  local path="$1" target="$2" tmpdir
  mkdir -p "$(dirname "$path")"
  tmpdir=$(mktemp -d "${path}.XXXXXX")
  ln -s "$target" "$tmpdir/link"
  mv -T "$tmpdir/link" "$path"
  rmdir "$tmpdir"
}

read_state() {
  local path="$1" fallback="$2"
  cat "$path" 2>/dev/null || printf '%s\n' "$fallback"
}

has_light_variant() {
  [ "$(jq -r '.hasLightVariant // false' "$PROFILES_DIR/$1/meta.json" 2>/dev/null)" = "true" ]
}

stop_bar() {
  case "$1" in
    noctalia)
      if ! systemctl --user stop noctalia-shell >/dev/null 2>&1; then
        echo "Error: failed to stop noctalia-shell." >&2
        return 1
      fi
      for _ in $(seq 1 20); do
        systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1 || break
        sleep 0.1
      done
      if systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1; then
        echo "Error: noctalia-shell did not stop." >&2
        return 1
      fi
      ;;
    waybar)
      pkill -f waybar >/dev/null 2>&1 || true
      for _ in $(seq 1 20); do
        pgrep -f waybar >/dev/null 2>&1 || break
        sleep 0.1
      done
      if pgrep -f waybar >/dev/null 2>&1; then
        echo "Error: waybar did not stop." >&2
        return 1
      fi
      ;;
    quickshell)
      pkill -f "quickshell.*quickshell/shell.qml" >/dev/null 2>&1 || true
      for _ in $(seq 1 20); do
        pgrep -f "quickshell.*quickshell/shell.qml" >/dev/null 2>&1 || break
        sleep 0.1
      done
      if pgrep -f "quickshell.*quickshell/shell.qml" >/dev/null 2>&1; then
        echo "Error: quickshell did not stop." >&2
        return 1
      fi
      ;;
  esac
}

start_bar_process() {
  case "$1" in
    noctalia) systemctl --user start noctalia-shell >/dev/null 2>&1 ;;
    waybar) waybar >/dev/null 2>&1 & ;;
    quickshell) quickshell -p "$REPO_HOME/configs/quickshell/shell.qml" >/dev/null 2>&1 & ;;
  esac
}

start_bar() {
  local profile="$1" variant="$2" bar="$3" dir style
  dir="$PROFILES_DIR/$profile"
  case "$bar" in
    noctalia) start_bar_process "$bar" ;;
    waybar)
      if [ -s "$dir/waybar-config.jsonc" ]; then
        mkdir -p "$CONFIG_HOME/waybar"
        install -m 644 "$dir/waybar-config.jsonc" "$CONFIG_HOME/waybar/config.jsonc"
        maybe_fail_stage "$CONFIG_HOME/waybar/config.jsonc"
        style=$(pick_variant_file "$variant" "$dir/waybar-style.css" "$dir/waybar-style-light.css")
        if [ -s "$style" ]; then
          install -m 644 "$style" "$CONFIG_HOME/waybar/style.css"
          maybe_fail_stage "$CONFIG_HOME/waybar/style.css"
        fi
      fi
      start_bar_process "$bar"
      ;;
    quickshell) start_bar_process "$bar" ;;
  esac
}

maybe_fail_stage() {
  if [ "${PROFILE_TRANSITION_FAIL_STAGE_PATH:-}" = "$1" ]; then
    echo "Error: injected staging failure for $1" >&2
    return "${PROFILE_TRANSITION_FAILURE_STATUS:-1}"
  fi
}

verify_bar() {
  local bar="$1"
  for _ in $(seq 1 20); do
    case "$bar" in
      noctalia) systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1 && return 0 ;;
      waybar) pgrep -f waybar >/dev/null 2>&1 && return 0 ;;
      quickshell) pgrep -f "quickshell.*quickshell/shell.qml" >/dev/null 2>&1 && return 0 ;;
    esac
    sleep 0.1
  done
  echo "Error: $bar failed to become ready." >&2
  return 1
}

[ $# -ge 1 ] || usage
MODE="$1"
shift

CURRENT=$(read_state "$ACTIVE_FILE" "")
CURRENT_VARIANT=$(read_state "$VARIANT_FILE" "dark")

case "$MODE" in
  switch)
    [ $# -eq 1 ] || usage
    TARGET="$1"
    TARGET_VARIANT=$(read_state "$PROFILES_DIR/variant-$TARGET" "dark")
    WRITE_PREFERENCE=1
    ;;
  variant)
    [ $# -eq 1 ] || usage
    [ -n "$CURRENT" ] || { echo "Error: no active profile." >&2; exit 1; }
    TARGET="$CURRENT"
    case "$1" in
      dark | light) TARGET_VARIANT="$1" ;;
      toggle)
        if [ "$CURRENT_VARIANT" = "dark" ]; then TARGET_VARIANT="light"; else TARGET_VARIANT="dark"; fi
        ;;
      *) usage ;;
    esac
    WRITE_PREFERENCE=1
    ;;
  reapply)
    [ $# -eq 0 ] || usage
    [ -n "$CURRENT" ] || { echo "Error: no active profile to reapply." >&2; exit 1; }
    TARGET="$CURRENT"
    TARGET_VARIANT="$CURRENT_VARIANT"
    WRITE_PREFERENCE=1
    ;;
  startup)
    [ $# -le 1 ] || usage
    TARGET="${1:-${CURRENT:-noctalia}}"
    if [ $# -eq 1 ] && [ "$TARGET" != "$CURRENT" ]; then
      TARGET_VARIANT=$(read_state "$PROFILES_DIR/variant-$TARGET" "dark")
    else
      TARGET_VARIANT="$CURRENT_VARIANT"
    fi
    WRITE_PREFERENCE=0
    if [ ! -d "$PROFILES_DIR/$TARGET" ]; then
      TARGET="noctalia"
      TARGET_VARIANT="dark"
    fi
    ;;
  *) usage ;;
esac

[ -d "$PROFILES_DIR/$TARGET" ] || { echo "Error: profile '$TARGET' not found." >&2; exit 1; }
if [ "$TARGET_VARIANT" = "light" ] && ! has_light_variant "$TARGET"; then
  echo "Error: profile '$TARGET' has no light variant." >&2
  exit 1
fi

LOCK_PATH="${PROFILE_TRANSITION_LOCK:-$HOME/.local/state/desktop-profiles/transition.lock}"
mkdir -p "$(dirname "$LOCK_PATH")"
exec 9>"$LOCK_PATH"
flock -n 9 || { echo "Error: another profile transition is in progress." >&2; exit 75; }

OLD_ACTIVE=$(read_state "$ACTIVE_FILE" "")
OLD_VARIANT=$(read_state "$VARIANT_FILE" "dark")
CURRENT_BAR="noctalia"
if [ -n "$OLD_ACTIVE" ] && [ -f "$PROFILES_DIR/$OLD_ACTIVE/meta.json" ]; then
  CURRENT_BAR=$(profile_bar "$OLD_ACTIVE")
fi
TARGET_BAR=$(profile_bar "$TARGET")

cleanup_transaction() {
  local status="$1"
  trap - EXIT INT TERM HUP
  rm -rf "$TRANSACTION_DIR" || true
  exit "$status"
}
TRANSACTION_ROOT="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}"
mkdir -p "$TRANSACTION_ROOT"
TRANSACTION_DIR=$(mktemp -d "$TRANSACTION_ROOT/profile-transition.XXXXXX")
trap 'cleanup_transaction $?' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP
chmod 700 "$TRANSACTION_DIR"
SNAPSHOT_COUNT=0
declare -a SNAPSHOT_KINDS=()
declare -a SNAPSHOT_PATHS=()
declare -a SNAPSHOT_PAYLOADS=()

snapshot_path() {
  local path="$1" kind payload=""
  SNAPSHOT_COUNT=$((SNAPSHOT_COUNT + 1))
  if [ -L "$path" ]; then
    kind=symlink
    [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != payload ] || return 23
    IFS= read -r -d '' payload < <(readlink -z -- "$path") || return $?
  elif [ -f "$path" ]; then
    kind=file
    payload="$TRANSACTION_DIR/$SNAPSHOT_COUNT"
    [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != payload ] || return 23
    cp -p -- "$path" "$payload" || return $?
  elif [ ! -e "$path" ]; then
    kind=missing
  else
    echo "Error: cannot snapshot unsupported path: $path" >&2
    return 1
  fi
  [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != manifest ] || return 24
  SNAPSHOT_KINDS+=("$kind")
  SNAPSHOT_PATHS+=("$path")
  SNAPSHOT_PAYLOADS+=("$payload")
  if [ -n "${PROFILE_TRANSITION_SIGNAL_DURING_SNAPSHOT:-}" ]; then
    kill -s "$PROFILE_TRANSITION_SIGNAL_DURING_SNAPSHOT" "$$"
  fi
}

snapshot_or_abort() {
  local status
  set +e
  snapshot_path "$1"
  status=$?
  set -e
  [ "$status" -ne 0 ] || return 0
  exit "$status"
}

restore_snapshot() {
  local index kind payload path tmp restore_errors=0
  for ((index=${#SNAPSHOT_PATHS[@]} - 1; index >= 0; index--)); do
    kind="${SNAPSHOT_KINDS[$index]}"
    path="${SNAPSHOT_PATHS[$index]}"
    payload="${SNAPSHOT_PAYLOADS[$index]}"
    if [ "${PROFILE_TRANSITION_FAIL_RESTORE_PATH:-}" = "$path" ] \
      && [ "${RESTORE_FAILURE_INJECTED:-0}" -eq 0 ]; then
      RESTORE_FAILURE_INJECTED=1
      echo "rollback: restore $path failed" >&2
      restore_errors=1
      continue
    fi
    case "$kind" in
      missing)
        rm -f -- "$path" || restore_errors=1
        ;;
      file)
        mkdir -p "$(dirname "$path")" || { restore_errors=1; continue; }
        tmp=$(mktemp "${path}.XXXXXX") || { restore_errors=1; continue; }
        if ! cp -p -- "$payload" "$tmp" || ! mv -f -- "$tmp" "$path"; then
          rm -f -- "$tmp"
          echo "rollback: restore $path failed" >&2
          restore_errors=1
        fi
        ;;
      symlink)
        if ! link_atomic "$path" "$payload"; then
          echo "rollback: restore $path failed" >&2
          restore_errors=1
        fi
        ;;
    esac
  done
  return "$restore_errors"
}

rollback() {
  local status="$1" rollback_errors=0
  trap - EXIT INT TERM HUP
  set +e
  rollback_try() {
    local label="$1"
    shift
    if ! "$@"; then
      echo "rollback: $label failed" >&2
      rollback_errors=1
    fi
  }
  rollback_try "target bar stop" stop_bar "$TARGET_BAR"
  rollback_try "snapshot restore" restore_snapshot
  rollback_try "Niri reload" niri msg action load-config-file
  if [ -n "$OLD_ACTIVE" ] && [ -f "$PROFILES_DIR/$OLD_ACTIVE/meta.json" ]; then
    rollback_try "previous bar restart" start_bar_process "$CURRENT_BAR"
    rollback_try "previous bar verification" verify_bar "$CURRENT_BAR"
  fi
  rollback_try "snapshot cleanup" rm -rf "$TRANSACTION_DIR"
  [ "$rollback_errors" -eq 0 ] || echo "rollback: one or more recovery operations failed" >&2
  exit "$status"
}

commit_transaction() {
  if [ "$WRITE_PREFERENCE" -eq 1 ]; then
    write_atomic "$ACTIVE_FILE" "$TARGET"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != active ] || return 1
    write_atomic "$VARIANT_FILE" "$TARGET_VARIANT"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != variant ] || return 1
    write_atomic "$PROFILES_DIR/variant-$TARGET" "$TARGET_VARIANT"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != preference ] || return 1
  fi
  rm -rf "$TRANSACTION_DIR"
  trap - EXIT INT TERM HUP
}

if [ "$WRITE_PREFERENCE" -eq 1 ]; then
  snapshot_or_abort "$ACTIVE_FILE"
  snapshot_or_abort "$VARIANT_FILE"
  snapshot_or_abort "$PROFILES_DIR/variant-$TARGET"
fi
snapshot_or_abort "$ACTIVE_LINK"
if [ "$TARGET_BAR" = waybar ] && [ -s "$PROFILES_DIR/$TARGET/waybar-config.jsonc" ]; then
  snapshot_or_abort "$CONFIG_HOME/waybar/config.jsonc"
  if [ -s "$(pick_variant_file "$TARGET_VARIANT" \
    "$PROFILES_DIR/$TARGET/waybar-style.css" \
    "$PROFILES_DIR/$TARGET/waybar-style-light.css")" ]; then
    snapshot_or_abort "$CONFIG_HOME/waybar/style.css"
  fi
fi
if [ -n "${PROFILE_TRANSITION_TEST_FILE_PATH:-}" ]; then
  snapshot_or_abort "$PROFILE_TRANSITION_TEST_FILE_PATH"
fi
if [ -n "${PROFILE_TRANSITION_TEST_SYMLINK_PATH:-}" ]; then
  snapshot_or_abort "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
fi
trap 'rollback $?' EXIT

if [ -n "${PROFILE_TRANSITION_TEST_MUTATE_SNAPSHOTS:-}" ]; then
  printf 'mutated\n' > "$PROFILE_TRANSITION_TEST_FILE_PATH"
  rm -f -- "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
  ln -s -- changed "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
  exit 29
fi

stop_bar "$CURRENT_BAR"
NIRI_OVERRIDE="$PROFILES_DIR/$TARGET/niri-overrides.kdl"
if [ "$(read_state "$FOCUS_FILE" "off")" = "on" ] && [ "$TARGET" != "noctalia" ]; then
  NIRI_OVERRIDE="$PROFILES_DIR/$TARGET/niri-overrides-focus.kdl"
fi
link_atomic "$ACTIVE_LINK" "$NIRI_OVERRIDE"
niri msg action load-config-file >/dev/null 2>&1
start_bar "$TARGET" "$TARGET_VARIANT" "$TARGET_BAR"
verify_bar "$TARGET_BAR"

commit_transaction
