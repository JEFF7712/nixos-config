#!/usr/bin/env bash
set -euo pipefail

STARTUP_MODE=0
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

wait_for_awww() {
  local attempts="${1:-20}"

  for _ in $(seq 1 "$attempts"); do
    if awww query >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.25
  done

  return 1
}

list_profiles() {
  local current=""
  [ -f "$ACTIVE_FILE" ] && current=$(cat "$ACTIVE_FILE")
  echo "Available profiles:"
  for dir in "$PROFILES_DIR"/*/; do
    [ -d "$dir" ] || continue
    name=$(basename "$dir")
    if [ "$name" = "$current" ]; then
      echo "  * $name (active)"
    else
      echo "    $name"
    fi
  done
}

if [ "${1:-}" = "--startup" ]; then
  STARTUP_MODE=1
  shift
fi

if [ $STARTUP_MODE -eq 0 ] && [ $# -eq 0 ]; then
  list_profiles
  exit 0
fi

if [ $STARTUP_MODE -eq 0 ] && { [ "$1" = "-t" ] || [ "$1" = "--toggle" ]; }; then
  exec toggle-variant
fi

if [ $STARTUP_MODE -eq 1 ]; then
  TARGET="${1:-$(cat "$ACTIVE_FILE" 2>/dev/null || echo "noctalia")}"
  TARGET_VARIANT=$(cat "$VARIANT_FILE" 2>/dev/null || echo "dark")
else
  TARGET="$1"
  TARGET_VARIANT="dark"
fi

TARGET_DIR="$PROFILES_DIR/$TARGET"
TARGET_RUNTIME="$TARGET_DIR/runtime.json"

if [ $STARTUP_MODE -eq 1 ] && [ ! -d "$TARGET_DIR" ]; then
  TARGET="noctalia"
  TARGET_DIR="$PROFILES_DIR/$TARGET"
  TARGET_RUNTIME="$TARGET_DIR/runtime.json"
  TARGET_VARIANT="dark"
fi

if [ ! -d "$TARGET_DIR" ]; then
  if [ $STARTUP_MODE -eq 1 ]; then
    echo "Warning: profile '$TARGET' not found during startup; skipping." >&2
    exit 0
  fi
  echo "Error: profile '$TARGET' not found." >&2
  list_profiles
  exit 1
fi

# Read currently running bar from active profile
CURRENT_BAR="noctalia"
if [ -f "$ACTIVE_FILE" ]; then
  CURRENT=$(cat "$ACTIVE_FILE")
  if [ -f "$PROFILES_DIR/$CURRENT/meta.json" ]; then
    CURRENT_BAR=$(jq -r '.bar' "$PROFILES_DIR/$CURRENT/meta.json")
  fi
fi

TARGET_BAR=$(jq -r '.bar' "$TARGET_DIR/meta.json")
TARGET_CURSOR=$(jq -r '.cursor' "$TARGET_DIR/meta.json")
TARGET_CURSOR_SIZE=$(jq -r '.cursorSize' "$TARGET_DIR/meta.json")
TARGET_WALLPAPER_DIR_FILE=$(pick_variant_file "$TARGET_VARIANT" "$TARGET_DIR/wallpaper-dir" "$TARGET_DIR/wallpaper-dir-light")
TARGET_WALLPAPER_DIR=$(cat "$TARGET_WALLPAPER_DIR_FILE" 2>/dev/null || echo "")

echo "Switching to profile: $TARGET"

# 1. Stop current bar
if [ $STARTUP_MODE -eq 0 ] && [ "$CURRENT_BAR" = "noctalia" ]; then
  echo "  Stopping noctalia-shell..."
  systemctl --user stop noctalia-shell 2>/dev/null || true
elif [ $STARTUP_MODE -eq 0 ] && [ "$CURRENT_BAR" = "waybar" ]; then
  echo "  Stopping waybar..."
  pkill -f waybar 2>/dev/null || true
  # Wait up to 2s for waybar to fully exit before proceeding
  for _ in $(seq 1 20); do
    pgrep -f waybar >/dev/null 2>&1 || break
    sleep 0.1
  done
  # Clean up waybar configs so a stale Nord config doesn't persist
  rm -f "$HOME/.config/waybar/config.jsonc" "$HOME/.config/waybar/style.css" 2>/dev/null || true
  # Stop mako (nord uses mako; noctalia manages its own notifications)
  pkill -x mako 2>/dev/null || true
elif [ $STARTUP_MODE -eq 0 ] && { [ "$CURRENT_BAR" = "clean" ] || [ "$CURRENT_BAR" = "quickshell" ]; }; then
  echo "  Stopping quickshell topbar..."
  pkill -f "quickshell.*quickshell-clean/shell.qml" 2>/dev/null || true
  pkill -x mako 2>/dev/null || true
fi

# 2. Copy color files (skip for noctalia — it manages its own colors)
if [ $STARTUP_MODE -eq 0 ] && [ "$TARGET" != "noctalia" ]; then
  echo "  Applying color files..."
  copy_profile_colors "$TARGET_DIR" "$TARGET_VARIANT"
  write_firefox_globals "$TARGET_RUNTIME" "$TARGET_VARIANT"
  systemctl --user restart swayosd 2>/dev/null || true
  # Generate pywal cache and push colors to Firefox via pywalfox
  if command -v wal >/dev/null 2>&1; then
    echo "  Generating pywal colors..."
    WAL_THEME=$(profile_runtime_string "$TARGET_RUNTIME" "$TARGET_VARIANT" pywal)
    [ -n "$WAL_THEME" ] || WAL_THEME="base16-nord"
    wal --theme "$WAL_THEME" -q 2>/dev/null || true
    command -v pywalfox >/dev/null 2>&1 && pywalfox update 2>/dev/null || true
  fi
fi

# 3. Update niri overrides symlink atomically (tmp + mv avoids missing-file window)
echo "  Updating niri overrides..."
TMPLINK=$(mktemp -u "$PROFILES_DIR/.active-niri-overrides.XXXXXX")
ln -s "$TARGET_DIR/niri-overrides.kdl" "$TMPLINK"
mv "$TMPLINK" "$ACTIVE_LINK"

# 4. Reload niri (picks up new cursor, borders, shadow, tab-indicator, opacity)
niri msg action reload-config 2>/dev/null || true

# 5. Apply cursor to GTK/XDG layer
echo "  Applying cursor..."
gsettings set org.gnome.desktop.interface cursor-theme "$TARGET_CURSOR"   2>/dev/null || true
gsettings set org.gnome.desktop.interface cursor-size  "$TARGET_CURSOR_SIZE" 2>/dev/null || true
set_gtk_setting "$CONFIG_HOME/gtk-3.0/settings.ini" gtk-cursor-theme-name "$TARGET_CURSOR"
set_gtk_setting "$CONFIG_HOME/gtk-3.0/settings.ini" gtk-cursor-theme-size "$TARGET_CURSOR_SIZE"
set_gtk_setting "$CONFIG_HOME/gtk-4.0/settings.ini" gtk-cursor-theme-name "$TARGET_CURSOR"
set_gtk_setting "$CONFIG_HOME/gtk-4.0/settings.ini" gtk-cursor-theme-size "$TARGET_CURSOR_SIZE"
apply_profile_fonts "$CONFIG_HOME" "$TARGET_DIR/meta.json"
apply_profile_appearance "$CONFIG_HOME" "$TARGET_DIR/meta.json" "$TARGET_VARIANT"

# 6. Record active profile and variant preference
if [ $STARTUP_MODE -eq 0 ]; then
  echo "$TARGET" > "$ACTIVE_FILE"
  echo "dark" > "$VARIANT_FILE"
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
elif [ "$TARGET_VARIANT" = "light" ]; then
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-light' 2>/dev/null || true
else
  gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' 2>/dev/null || true
fi

# 6b. Start new bar + manage awww (noctalia has its own wallpaper engine; waybar needs awww)
if [ "$TARGET_BAR" = "noctalia" ]; then
  echo "  Starting noctalia-shell..."
  systemctl --user stop awww 2>/dev/null || true  # noctalia owns the wallpaper layer
  systemctl --user start noctalia-shell 2>/dev/null || true
  sleep 1  # allow noctalia to come up before IPC call
elif [ "$TARGET_BAR" = "waybar" ]; then
  echo "  Starting waybar..."
  systemctl --user start awww 2>/dev/null || true  # awww needed for static wallpapers
  if [ -f "$TARGET_DIR/waybar-config.jsonc" ]; then
    WAYBAR_STYLE=$(pick_variant_file "$TARGET_VARIANT" "$TARGET_DIR/waybar-style.css" "$TARGET_DIR/waybar-style-light.css")
    mkdir -p "$HOME/.config/waybar"
    # Home Manager generates profile files as read-only; install writable copies
    # so repeated profile switches can update the live config.
    install -m 644 "$TARGET_DIR/waybar-config.jsonc" "$HOME/.config/waybar/config.jsonc"
    install -m 644 "$WAYBAR_STYLE" "$HOME/.config/waybar/style.css"
  fi
  if [ -f "$TARGET_DIR/mako-config" ]; then
    MAKO_CONFIG=$(pick_variant_file "$TARGET_VARIANT" "$TARGET_DIR/mako-config" "$TARGET_DIR/mako-config-light")
    mkdir -p "$HOME/.config/mako"
    install -m 644 "$MAKO_CONFIG" "$HOME/.config/mako/config"
  fi
  apply_profile_fonts "$CONFIG_HOME" "$TARGET_DIR/meta.json"
  apply_profile_appearance "$CONFIG_HOME" "$TARGET_DIR/meta.json" "$TARGET_VARIANT"
  if [ $STARTUP_MODE -eq 1 ]; then
    pgrep -f waybar >/dev/null 2>&1 || {
      waybar 2>/dev/null &
      disown
    }
  else
    waybar 2>/dev/null &
    disown
  fi
  # Start mako for waybar profile notifications
  if [ $STARTUP_MODE -eq 1 ]; then
    pgrep -x mako >/dev/null 2>&1 || {
      mako 2>/dev/null &
      disown
    }
  else
    mako 2>/dev/null &
    disown
  fi
elif [ "$TARGET_BAR" = "clean" ] || [ "$TARGET_BAR" = "quickshell" ]; then
  echo "  Starting quickshell topbar..."
  systemctl --user start awww 2>/dev/null || true
  pkill -f "quickshell.*quickshell-clean/shell.qml" 2>/dev/null || true
  quickshell -p "$REPO_HOME/configs/quickshell-clean/shell.qml" 2>/dev/null &
  disown

  if [ -f "$TARGET_DIR/mako-config" ]; then
    MAKO_CONFIG=$(pick_variant_file "$TARGET_VARIANT" "$TARGET_DIR/mako-config" "$TARGET_DIR/mako-config-light")
    mkdir -p "$HOME/.config/mako"
    install -m 644 "$MAKO_CONFIG" "$HOME/.config/mako/config"
  fi
  apply_profile_fonts "$CONFIG_HOME" "$TARGET_DIR/meta.json"
  apply_profile_appearance "$CONFIG_HOME" "$TARGET_DIR/meta.json" "$TARGET_VARIANT"

  if [ $STARTUP_MODE -eq 1 ]; then
    pgrep -x mako >/dev/null 2>&1 || {
      mako 2>/dev/null &
      disown
    }
  else
    mako 2>/dev/null &
    disown
  fi
fi

# 6c. Profile switcher popup — runs as a standalone Quickshell instance on
# every profile (started here if not already running; idempotent).
SWITCHER_PATH="$REPO_HOME/configs/quickshell-switcher/shell.qml"
if ! pgrep -f "quickshell.*quickshell-switcher/shell.qml" >/dev/null 2>&1; then
  quickshell -p "$SWITCHER_PATH" >/dev/null 2>&1 &
  disown
fi

# 6d. Custom app launcher — standalone Quickshell instance for all non-noctalia
# profiles. Noctalia keeps its own launcher (we still start ours but it just
# sits idle since Mod+Space routes to noctalia's IPC on that profile).
LAUNCHER_PATH="$REPO_HOME/configs/quickshell-launcher/shell.qml"
if ! pgrep -f "quickshell.*quickshell-launcher/shell.qml" >/dev/null 2>&1; then
  quickshell -p "$LAUNCHER_PATH" >/dev/null 2>&1 &
  disown
fi

# 7. Set wallpaper (after bar start so noctalia IPC is available)
echo "  Setting wallpaper..."
if [ "$TARGET" = "noctalia" ]; then
  # wallpaper random requires a screen argument; call it for each connected output
  while IFS= read -r screen; do
    noctalia-shell ipc --any-display call wallpaper random "$screen" 2>/dev/null || true
  done < <(niri msg outputs 2>/dev/null | grep '^Output ' | sed 's/^Output ".*" (\(.*\))/\1/')
  # Wait for noctalia to generate colors.json, then apply user templates (including kitty)
  (
    sleep 4
    NOCSHELL=$(readlink -f "$(which noctalia-shell)")
    NOCBASE="${NOCSHELL%/bin/noctalia-shell}"
    SCRIPTS="$NOCBASE/share/noctalia-shell/Scripts/python/src/theming"
    if [ -f "$SCRIPTS/template-processor.py" ] && [ -f "$HOME/.config/noctalia/colors.json" ]; then
      cd "$SCRIPTS" && python3 template-processor.py \
        --scheme "$HOME/.config/noctalia/colors.json" \
        --config "$HOME/.config/noctalia/user-templates.toml" \
        --mode dark 2>/dev/null || true
    fi
  ) &
elif [ -d "$TARGET_WALLPAPER_DIR" ]; then
  WALLPAPER=$(pick_random_wallpaper "$TARGET_WALLPAPER_DIR")
  if [ -n "$WALLPAPER" ]; then
    wait_for_awww 20
    awww img "$WALLPAPER" --transition-type fade --transition-duration 1 2>/dev/null || true
  else
    echo "  Warning: no wallpaper images found in $TARGET_WALLPAPER_DIR"
  fi
  # Update waypaper config so its folder picker opens the right directory
  WAYPAPER_CFG="$HOME/.config/waypaper/config.ini"
  if [ -f "$WAYPAPER_CFG" ] && [ -n "$TARGET_WALLPAPER_DIR" ]; then
    WAYPAPER_FOLDER="${TARGET_WALLPAPER_DIR/#$HOME/\~}"
    sed -i "s|^folder = .*|folder = $WAYPAPER_FOLDER|" "$WAYPAPER_CFG"
    [ -n "$WALLPAPER" ] && sed -i "s|^wallpaper = .*|wallpaper = ${WALLPAPER/#$HOME/\~}|" "$WAYPAPER_CFG"
  fi
fi

# 8. Signal kitty to reload colors (noctalia handles this via template-processor post_hook)
if [ $STARTUP_MODE -eq 0 ] && [ "$TARGET" != "noctalia" ]; then
  pkill -USR1 -x kitty 2>/dev/null || true
fi

if [ $STARTUP_MODE -eq 0 ]; then
  # 9. Update per-app themes (Zed, Vesktop, Obsidian)
  apply_zed_theme "$TARGET_RUNTIME" "$TARGET_VARIANT"
  apply_vesktop_theme "$TARGET_RUNTIME" "$TARGET_VARIANT"
  apply_obsidian_scheme "$TARGET_RUNTIME" "$TARGET_VARIANT"

  # 10. Notify
  notify-send "Desktop Profile" "Switched to $TARGET" 2>/dev/null || true
  echo "Done. Profile '$TARGET' is now active."
else
  echo "Done. Startup profile '$TARGET' reapplied."
fi
