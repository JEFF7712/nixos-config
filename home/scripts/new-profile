#!/usr/bin/env bash
# Scaffold a new desktop profile built on the static-profile default mapping.
# Creates modules/home-manager/profiles/<name>.nix (auto-discovered by
# import-tree), the wallpaper directory, and registers the file with git so
# flake evaluation can see it.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

NAME="${1:-}"
if [ -z "$NAME" ]; then
  echo "Usage: new-profile <name>" >&2
  exit 1
fi
if ! printf '%s' "$NAME" | grep -Eq '^[a-z][a-z0-9-]*$'; then
  echo "Error: name must match ^[a-z][a-z0-9-]*$" >&2
  exit 1
fi

REPO_ROOT="$(dirname "$REPO_HOME")"
PROFILE_NIX="$REPO_ROOT/modules/home-manager/profiles/$NAME.nix"
WALLPAPERS="$REPO_HOME/assets/wallpapers/$NAME"

if [ -e "$PROFILE_NIX" ]; then
  echo "Error: $PROFILE_NIX already exists." >&2
  exit 1
fi

TITLE="$(printf '%s' "$NAME" | sed 's/./\U&/')"

cat > "$PROFILE_NIX" << 'EOF'
{ config, ... }:

let
  static = import ../../../lib/desktop-profiles/static-profile.nix;

  # Starting palette — replace with the theme's colors. Roles cascade; see
  # lib/desktop-profiles/static-profile.nix for the full vocabulary and
  # per-slot overrides.
  dark = rec {
    title = "__TITLE__ Dark";
    bg0 = "#1a1b26";
    bg1 = "#24283b";
    bg2 = "#2f3549";
    bg3 = "#3b4261";
    fg0 = "#e6ebf4";
    fg1 = "#c0caf5";
    fg2 = "#9aa5ce";
    fg4 = "#565f89";
    red = "#f7768e";
    orange = "#ff9e64";
    yellow = "#e0af68";
    green = "#9ece6a";
    aqua = "#73daca";
    blue = "#7aa2f7";
    purple = "#bb9af7";
    accent = blue;
    barBg = "rgba(26, 27, 38, 0.6)";
    barShadow = "rgba(0, 0, 0, 0.45)";
  };
in
{
  desktopProfiles.profiles.__NAME__ = static.mkStaticProfile {
    palette = dark;
    scriptDir = "${config.repoPath}/home/scripts";
    wallpaperDir = "${config.repoPath}/home/assets/wallpapers/__NAME__";

    cursor = {
      theme = "Bibata-Modern-Classic";
      size = 24;
    };

    fonts = {
      ui = {
        family = "Inter";
        size = 11;
      };
      mono = {
        family = "JetBrainsMono Nerd Font";
        size = 14;
      };
    };

    appearance = {
      gtkTheme = "adw-gtk3-dark";
      iconTheme = "Papirus-Dark";
    };

    niri = {
      gaps = 8;
      borderOff = true;
      focusRingOff = true;
      tabIndicatorOff = false;
      windowOpacity = 1.0;
      windowHighlightOff = true;
    };
  };
}
EOF

sed -i -e "s/__NAME__/$NAME/g" -e "s/__TITLE__/$TITLE/g" "$PROFILE_NIX"
mkdir -p "$WALLPAPERS"
git -C "$REPO_ROOT" add -N "$PROFILE_NIX" 2>/dev/null || true

echo "Created $PROFILE_NIX"
echo
echo "Next steps:"
echo "  1. Edit the palette (and add a light palette via paletteLight if wanted)"
echo "  2. Drop wallpapers into $WALLPAPERS"
echo "  3. Add a preview image at $REPO_HOME/assets/previews/$NAME.png (rofi picker)"
echo "  4. Rebuild, then: switch-profile $NAME"
