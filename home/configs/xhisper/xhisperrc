# xhisper configuration — see `xhisper --log` for transcription debug.
# Editable at runtime (this file is symlinked out-of-store).

# Whisper model: tiny, base, small, medium, large-v3 (and *.en variants for
# English-only after `nixos-rebuild switch` picks up the patched derivation).
model-name : small.en

# Device: auto, cpu, or cuda.
model-device : cuda

# Language: leave empty for auto-detect, or "en" for English-only.
model-language : "en"

transcription-prompt : "Technical dictation with AI, ML, Linux, NixOS, chemistry, and coding jargon. Prefer these spellings when heard: Rupan, Ramrupan Sunderapandyan, UW-Madison, Claude, Claude Code, CLAUDE.md, AGENTS.md, README.md, NixOS, nixpkgs, Home Manager, flake.nix, flake.lock, nix develop, nix shell, MCP, LLM, RAG, evals, embeddings, tokenizer, fine-tuning, LoRA, QLoRA, vLLM, Ollama, OpenAI, Anthropic, PyTorch, CUDA, Wayland, niri, Quickshell, GitHub, git, fish, uv, pyright, Arch Linux, Docker, homelab, agentic AI, AI agents, mechanistic interpretability, foundation models, world models, AI capabilities, artificial minds, recursive self-improvement, scientific ML, AI-for-science, computational chemistry, molecular ML, molecular dynamics, molecular modeling, cheminformatics, protein dynamics, drug discovery, ApptlyAI, rupan.dev, soluble.rupan.dev, DESRES."

non-ascii-initial-delay : 0.15
non-ascii-default-delay : 0.025

silence-threshold  : -50
silence-percentage : 95

# AI post-processing via local Ollama. Empty = type raw Whisper output.
# gemma3:4b drifts/paraphrases on long inputs — leave empty unless you want
# light grammar/punctuation fixes on short utterances.
post-process-model     :
post-process-timeout   : 10
post-process-mode      : auto
