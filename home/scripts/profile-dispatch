#!/usr/bin/env bash
# profile-dispatch <action>
# Routes profile-aware desktop actions to the right backend so niri keybinds
# stay one-liners. The noctalia bar handles these itself via IPC; everything
# else uses the generic tools (swayosd, waypaper, quickshell launcher).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

ACTIVE=$(cat "$ACTIVE_FILE" 2>/dev/null || echo "")
BAR="noctalia"
[ -n "$ACTIVE" ] && BAR=$(profile_bar "$ACTIVE")

# Per action: the noctalia IPC subcommand (appended to `noctalia-shell ipc
# --any-display call`) and the generic command for every other bar. To add an
# action, add one row to each table; to add a bar backend, branch on $BAR below.
declare -A NOCTALIA=(
  [launcher]="launcher toggle"
  [wallpaper]="wallpaper toggle"
  [volume-up]="volume increase"
  [volume-down]="volume decrease"
  [volume-mute]="volume muteOutput"
  [brightness-up]="brightness increase"
  [brightness-down]="brightness decrease"
)
declare -A GENERIC=(
  [launcher]="qs -p $REPO_HOME/configs/quickshell-launcher ipc call launcher toggle"
  [wallpaper]="waypaper"
  [volume-up]="swayosd-client --output-volume raise"
  [volume-down]="swayosd-client --output-volume lower"
  [volume-mute]="swayosd-client --output-volume mute-toggle"
  [brightness-up]="swayosd-client --brightness raise"
  [brightness-down]="swayosd-client --brightness lower"
)

ACTION="${1:-}"
if [ -z "$ACTION" ] || [ -z "${NOCTALIA[$ACTION]:-}" ]; then
  echo "Usage: profile-dispatch <$(
    IFS='|'
    echo "${!NOCTALIA[*]}"
  )>" >&2
  exit 1
fi

# Word-splitting on the table value is intentional (the commands are trusted
# constants; $REPO_HOME holds no spaces).
if [ "$BAR" = "noctalia" ]; then
  # shellcheck disable=SC2086
  noctalia-shell ipc --any-display call ${NOCTALIA[$ACTION]}
else
  if [ "$ACTION" = "wallpaper" ]; then
    ensure_waypaper_post_command
  fi
  # shellcheck disable=SC2086
  ${GENERIC[$ACTION]}
fi
