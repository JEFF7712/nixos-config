#!/usr/bin/env bash
set -euo pipefail

: "${QS_TEST_STATE_DIR:?QS_TEST_STATE_DIR is required}"

state_file="$QS_TEST_STATE_DIR/audio.state"
actions_file="$QS_TEST_STATE_DIR/audio-actions.log"
lock_dir="$QS_TEST_STATE_DIR/wpctl.lock"

read_state() {
  volume=$(awk -F= '$1 == "volume" { print $2 }' "$state_file")
  mute=$(awk -F= '$1 == "mute" { print $2 }' "$state_file")
}

write_state() {
  local temporary="$state_file.$$"
  {
    printf 'volume=%s\n' "$volume"
    printf 'mute=%s\n' "$mute"
  } >"$temporary"
  mv -f "$temporary" "$state_file"
}

if [ "$#" -eq 2 ] && [ "$1" = get-volume ] && [ "$2" = '@DEFAULT_AUDIO_SINK@' ]; then
  operation=get-volume
elif [ "$#" -eq 5 ] && [ "$1" = set-volume ] && [ "$2" = -l ] && [ "$3" = 1.0 ] && [ "$4" = '@DEFAULT_AUDIO_SINK@' ] && [[ "$5" =~ ^([0-9]|[1-9][0-9]|100)%$ ]]; then
  operation=set-volume
elif [ "$#" -eq 3 ] && [ "$1" = set-mute ] && [ "$2" = '@DEFAULT_AUDIO_SINK@' ] && [ "$3" = toggle ]; then
  operation=set-mute
else
  printf 'unsupported wpctl argv:' >&2
  printf ' <%s>' "$@" >&2
  printf '\n' >&2
  exit 64
fi

mkdir "$lock_dir" 2>/dev/null || {
  printf 'overlap %s\n' "$*" >>"$QS_TEST_STATE_DIR/audio-overlap.log"
  exit 70
}
trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT
sleep 0.08
read_state

if [ "$operation" = get-volume ]; then
  printf 'get-volume\n' >>"$QS_TEST_STATE_DIR/audio-probes.log"
  probe_mode=valid
  if [ -s "$QS_TEST_STATE_DIR/audio-probe-mode" ]; then
    probe_mode=$(<"$QS_TEST_STATE_DIR/audio-probe-mode")
  fi
  if [ "$probe_mode" = malformed ]; then
    printf 'default sink unavailable\n'
    exit 0
  elif [ "$probe_mode" = missing ]; then
    exit 3
  elif [ "$probe_mode" != valid ]; then
    printf 'unsupported audio probe mode: %s\n' "$probe_mode" >&2
    exit 64
  fi
  printf 'Volume: %s' "$volume"
  [ "$mute" = 1 ] && printf ' [MUTED]'
  printf '\n'
elif [ "$operation" = set-volume ]; then
  percent=${5%%%}
  volume=$(awk -v percent="$percent" 'BEGIN { printf "%.2f", percent / 100 }')
  write_state
  printf 'set-volume %s\n' "$percent" >>"$actions_file"
else
  if [ "$mute" = 1 ]; then mute=0; else mute=1; fi
  if [ -s "$QS_TEST_STATE_DIR/confirmation-volume" ]; then
    volume=$(<"$QS_TEST_STATE_DIR/confirmation-volume")
  fi
  write_state
  printf 'set-mute toggle\n' >>"$actions_file"
fi
