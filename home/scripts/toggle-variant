#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case "${1:-}" in
  dark | light | "") ;;
  *)
    echo "Usage: toggle-variant [dark|light]" >&2
    exit 1
    ;;
esac
[ $# -le 1 ] || { echo "Usage: toggle-variant [dark|light]" >&2; exit 1; }
exec "$SCRIPT_DIR/profile-transition" variant "${1:-toggle}"
