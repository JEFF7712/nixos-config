#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

list_profiles() {
  local current=""
  [ -f "$ACTIVE_FILE" ] && current=$(cat "$ACTIVE_FILE")
  echo "Available profiles:"
  for dir in "$PROFILES_DIR"/*/; do
    [ -d "$dir" ] || continue
    name=$(basename "$dir")
    if [ "$name" = "$current" ]; then
      echo "  * $name (active)"
    else
      echo "    $name"
    fi
  done
}

STATUS_FAILED=0

mark() {
  if [ "$1" = "ok" ]; then
    printf '  [ok]      %s\n' "$2"
  else
    printf '  [MISSING] %s\n' "$2"
    STATUS_FAILED=1
  fi
}

profile_status() {
  local active variant meta bar self link_target expected_target wallpaper_dir

  active=$(cat "$ACTIVE_FILE" 2>/dev/null || echo "")
  variant=$(cat "$VARIANT_FILE" 2>/dev/null || echo "dark")
  if [ -z "$active" ]; then
    echo "No active profile recorded."
    return 1
  fi

  meta="$PROFILES_DIR/$active/meta.json"
  bar=$(profile_bar "$active")
  self=$(jq -r '.selfThemed // false' "$meta" 2>/dev/null || echo "false")

  bar_note=""
  [ -s "$PROFILES_DIR/bar-$active" ] && bar_note=" [override]"
  echo "Profile: $active (variant: $variant, bar: $bar$bar_note, self-themed: $self)"

  case "$bar" in
    noctalia)
      if [ "$(systemctl --user is-active noctalia-shell 2>/dev/null)" = "active" ]; then
        mark ok "noctalia-shell service"
      else
        mark fail "noctalia-shell service"
      fi
      ;;
    waybar)
      pgrep -f waybar >/dev/null 2>&1 && mark ok "waybar" || mark fail "waybar"
      mako_running && mark ok "mako" || mark fail "mako"
      ;;
    quickshell)
      pgrep -f "quickshell.*quickshell/shell.qml" >/dev/null 2>&1 \
        && mark ok "quickshell topbar" || mark fail "quickshell topbar"
      # Quickshell owns notifications natively; mako must NOT be running (it would
      # steal the org.freedesktop.Notifications bus name).
      if busctl --user status org.freedesktop.Notifications 2>/dev/null | grep -qi quickshell; then
        mark ok "notification server"
      else
        mark fail "notification server (bus not owned by quickshell)"
      fi
      ;;
  esac

  pgrep -f "quickshell.*quickshell-switcher/shell.qml" >/dev/null 2>&1 \
    && mark ok "profile switcher popup" || mark fail "profile switcher popup"
  systemctl --user is-active --quiet vicinae.service \
    && mark ok "vicinae launcher" || mark fail "vicinae launcher"

  link_target=$(readlink "$ACTIVE_LINK" 2>/dev/null || echo "")
  if [ "$(cat "$FOCUS_FILE" 2>/dev/null)" = "on" ] && [ "$active" != "noctalia" ]; then
    expected_target="$PROFILES_DIR/$active/niri-overrides-focus.kdl"
  else
    expected_target="$PROFILES_DIR/$active/niri-overrides.kdl"
  fi
  if [ "$link_target" = "$expected_target" ]; then
    mark ok "niri overrides symlink$([ "$(cat "$FOCUS_FILE" 2>/dev/null)" = "on" ] && echo ' [focus]')"
  else
    mark fail "niri overrides symlink (-> ${link_target:-none})"
  fi

  wallpaper_dir=$(cat "$(pick_variant_file "$variant" \
    "$PROFILES_DIR/$active/wallpaper-dir" \
    "$PROFILES_DIR/$active/wallpaper-dir-light")" 2>/dev/null || echo "")
  if [ "$self" = "true" ] || [ -d "$wallpaper_dir" ]; then
    mark ok "wallpaper dir"
  else
    mark fail "wallpaper dir ($wallpaper_dir)"
  fi

  if [ $STATUS_FAILED -eq 1 ]; then
    echo "Run 'switch-profile --reapply' to restore the expected state."
    return 1
  fi
}

case "${1:-}" in
  --startup)
    shift
    [ $# -le 1 ] || { echo "Usage: switch-profile --startup [NAME]" >&2; exit 1; }
    if [ $# -eq 1 ]; then
      exec "$SCRIPT_DIR/profile-transition" startup "$1"
    fi
    exec "$SCRIPT_DIR/profile-transition" startup
    ;;
  --reapply)
    shift
    [ $# -eq 0 ] || { echo "Usage: switch-profile --reapply" >&2; exit 1; }
    exec "$SCRIPT_DIR/profile-transition" reapply
    ;;
  --status)
    profile_status
    exit $?
    ;;
  -t | --toggle)
    shift
    exec "$SCRIPT_DIR/toggle-variant" "$@"
    ;;
esac

if [ $# -eq 0 ]; then
  list_profiles
  exit 0
fi
[ $# -eq 1 ] || { echo "Usage: switch-profile NAME" >&2; exit 1; }
exec "$SCRIPT_DIR/profile-transition" switch "$1"
