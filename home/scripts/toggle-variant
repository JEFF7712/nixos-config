#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

. "$SCRIPT_DIR/profile-common"

PROFILE=$(cat "$ACTIVE_FILE" 2>/dev/null || echo "")
[ -n "$PROFILE" ] || { echo "No active profile." >&2; exit 1; }
PROFILE_DIR="$PROFILES_DIR/$PROFILE"
HAS_LIGHT=$(jq -r '.hasLightVariant // false' "$PROFILE_DIR/meta.json" 2>/dev/null || echo false)
if [ "$HAS_LIGHT" != true ]; then
  echo "Profile '$PROFILE' has no light variant, nothing to do."
  exit 0
fi

CURRENT=$(cat "$VARIANT_FILE" 2>/dev/null || echo dark)
case "${1:-}" in
  dark | light)
    if [ "$1" = "$CURRENT" ]; then
      echo "$PROFILE is already $CURRENT."
      exit 0
    fi
    ;;
  "") ;;
  *)
    echo "Usage: toggle-variant [dark|light]" >&2
    exit 1
    ;;
esac
[ $# -le 1 ] || { echo "Usage: toggle-variant [dark|light]" >&2; exit 1; }
exec "$SCRIPT_DIR/profile-transition" variant "${1:-toggle}"
