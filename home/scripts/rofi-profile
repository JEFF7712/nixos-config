#!/usr/bin/env bash
# Profile switcher using rofi dmenu mode.
# Rofi closes immediately after selection, then switch-profile runs in background.

PROFILES_DIR="$HOME/.config/desktop-profiles"
PREVIEW_DIR="$HOME/nixos/modules/home-manager/assets/previews"
ACTIVE=$(cat "$PROFILES_DIR/active" 2>/dev/null || echo "")
THEME="$HOME/nixos/modules/home-manager/configs/rofi/profile-switcher.rasi"

# Pipe entries directly to rofi — null bytes in the icon format are preserved
# through a pipe but get stripped by $() command substitution.
selected=$(
  for dir in "$PROFILES_DIR"/*/; do
    [ -d "$dir" ] || continue
    name=$(basename "$dir")
    label="$name"
    [ "$name" = "$ACTIVE" ] && label="$name (active)"
    preview="$PREVIEW_DIR/$name.png"
    if [ -f "$preview" ]; then
      printf "%s\0icon\x1f%s\n" "$label" "$preview"
    else
      printf "%s\n" "$label"
    fi
  done | rofi \
    -dmenu \
    -show-icons \
    -icon-theme Adwaita \
    -theme "$THEME"
)

[ -z "$selected" ] && exit 0

name="${selected% (active)}"
switch-profile "$name" >/dev/null 2>&1 </dev/null &
disown
