#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/profile-common"

usage() {
  echo "Usage: profile-transition switch NAME | variant dark|light|toggle | reapply | startup [NAME]" >&2
  exit 2
}

write_atomic() {
  local path="$1" value="$2" tmp
  mkdir -p "$(dirname "$path")"
  tmp=$(mktemp "${path}.XXXXXX")
  printf '%s\n' "$value" > "$tmp"
  mv "$tmp" "$path"
}

link_atomic() {
  local path="$1" target="$2" tmpdir
  mkdir -p "$(dirname "$path")"
  tmpdir=$(mktemp -d "${path}.XXXXXX")
  ln -s "$target" "$tmpdir/link"
  mv -T "$tmpdir/link" "$path"
  rmdir "$tmpdir"
}

read_state() {
  local path="$1" fallback="$2"
  cat "$path" 2>/dev/null || printf '%s\n' "$fallback"
}

has_light_variant() {
  profile_manifest_has_variant "$1" light
}

stop_bar() {
  local bar="$1" quickshell_pattern
  quickshell_pattern="quickshell.*$REPO_HOME/configs/quickshell/shell.qml"
  case "$bar" in
    noctalia)
      if ! systemctl --user stop noctalia-shell >/dev/null 2>&1; then
        echo "Error: failed to stop noctalia-shell." >&2
        return 1
      fi
      for _ in $(seq 1 20); do
        systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1 || break
        sleep 0.1
      done
      if systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1; then
        echo "Error: noctalia-shell did not stop." >&2
        return 1
      fi
      ;;
    waybar)
      pkill -f waybar >/dev/null 2>&1 || true
      for _ in $(seq 1 20); do
        pgrep -f waybar >/dev/null 2>&1 || break
        sleep 0.1
      done
      if pgrep -f waybar >/dev/null 2>&1; then
        echo "Error: waybar did not stop." >&2
        return 1
      fi
      stop_mako
      if ! wait_for_mako_shutdown; then
        echo "Error: Mako did not stop." >&2
        return 1
      fi
      ;;
    quickshell)
      pkill -f "$quickshell_pattern" >/dev/null 2>&1 || true
      for _ in $(seq 1 20); do
        pgrep -f "$quickshell_pattern" >/dev/null 2>&1 || break
        sleep 0.1
      done
      if pgrep -f "$quickshell_pattern" >/dev/null 2>&1; then
        echo "Error: quickshell did not stop." >&2
        return 1
      fi
      stop_mako
      if ! wait_for_mako_shutdown; then
        echo "Error: Mako did not stop." >&2
        return 1
      fi
      ;;
  esac
}

stop_all_bars() {
  stop_bar noctalia
  stop_bar waybar
  stop_bar quickshell
}

start_bar() {
  local bar="$1" theme_profile="$2" theme_variant="$3"
  case "$bar" in
    noctalia)
      stop_mako
      wait_for_mako_shutdown
      systemctl --user stop awww >/dev/null 2>&1 || true
      systemctl --user start noctalia-shell >/dev/null 2>&1
      ;;
    waybar)
      systemctl --user start awww >/dev/null 2>&1 || true
      waybar 9>&- >/dev/null 2>&1 &
      start_mako
      if [ "$(read_state "$FOCUS_FILE" off)" = on ]; then
        for _ in $(seq 1 15); do
          makoctl mode -a dnd >/dev/null 2>&1 && break
          sleep 0.1
        done
      fi
      ;;
    quickshell)
      systemctl --user start awww >/dev/null 2>&1 || true
      stop_mako
      wait_for_mako_shutdown
      DESKTOP_PROFILE_TRANSITION_TARGET="$theme_profile" \
        DESKTOP_PROFILE_TRANSITION_VARIANT="$theme_variant" \
        quickshell -p "$REPO_HOME/configs/quickshell/shell.qml" 9>&- >/dev/null 2>&1 &
      ;;
  esac
}

stage_bar_files() {
  local bar="$1" profile_dir="$2" variant="$3" stage_dir="$4"
  local stage_config="$stage_dir/home/.config" style mako_config profile
  [ "$bar" = waybar ] || return 0
  profile=$(basename "$profile_dir")
  mkdir -p "$stage_config/waybar" "$stage_config/mako"
  install -m 644 "$(profile_manifest_artifact "$profile" "$variant" waybar.config)" \
    "$stage_config/waybar/config.jsonc"
  style=$(profile_manifest_artifact "$profile" "$variant" "waybar.$variant")
  if [ -s "$style" ]; then
    install -m 644 "$style" "$stage_config/waybar/style.css"
  fi
  mako_config=$(profile_manifest_artifact "$profile" "$variant" "mako.$variant")
  if [ -s "$mako_config" ]; then
    install -m 644 "$mako_config" "$stage_config/mako/config"
  fi
}

maybe_fail_stage() {
  if [ "${PROFILE_TRANSITION_FAIL_STAGE_PATH:-}" = "$1" ]; then
    echo "Error: injected staging failure for $1" >&2
    return "${PROFILE_TRANSITION_FAILURE_STATUS:-1}"
  fi
}

verify_bar() {
  local bar="$1" quickshell_pattern
  quickshell_pattern="quickshell.*$REPO_HOME/configs/quickshell/shell.qml"
  for _ in $(seq 1 20); do
    case "$bar" in
      noctalia)
        systemctl --user is-active --quiet noctalia-shell >/dev/null 2>&1 \
          && notification_owner_is noctalia && return 0
        ;;
      waybar)
        pgrep -f waybar >/dev/null 2>&1 && notification_owner_is mako && return 0
        ;;
      quickshell)
        pgrep -f "$quickshell_pattern" >/dev/null 2>&1 \
          && notification_owner_is quickshell && return 0
        ;;
    esac
    sleep 0.1
  done
  echo "Error: $bar failed to become ready." >&2
  return 1
}

notification_owner_is() {
  local expected="$1"
  busctl --user status org.freedesktop.Notifications 2>/dev/null | grep -qi "$expected"
}

apply_system_preferences() {
  local cursor cursor_size gtk_theme icon_theme color_scheme failed=0
  IFS=$'\t' read -r cursor cursor_size gtk_theme icon_theme < <(
    jq -r --arg variant "$TARGET_VARIANT" '
      [.transition.cursor.theme, .transition.cursor.size,
       (if $variant == "light" then (.transition.appearance.gtkThemeLight // .transition.appearance.gtkTheme) else .transition.appearance.gtkTheme end),
       (if $variant == "light" then (.transition.appearance.iconThemeLight // .transition.appearance.iconTheme) else .transition.appearance.iconTheme end)] | @tsv' \
      "$TARGET_DIR/manifest.json"
  )
  color_scheme=prefer-dark
  [ "$TARGET_VARIANT" != light ] || color_scheme=prefer-light
  gsettings set org.gnome.desktop.interface cursor-theme "$cursor" 2>/dev/null || failed=1
  gsettings set org.gnome.desktop.interface cursor-size "$cursor_size" 2>/dev/null || failed=1
  gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" 2>/dev/null || failed=1
  gsettings set org.gnome.desktop.interface icon-theme "$icon_theme" 2>/dev/null || failed=1
  gsettings set org.gnome.desktop.interface color-scheme "$color_scheme" 2>/dev/null || failed=1
  return "$failed"
}

apply_static_wallpaper() {
  local wallpaper="" waypaper_config waypaper_folder
  [ -d "$TARGET_WALLPAPER_DIR" ] || return 0
  wallpaper=$(pick_random_wallpaper "$TARGET_WALLPAPER_DIR")
  if [ -z "$wallpaper" ]; then
    echo "Warning: no supported wallpapers found in $TARGET_WALLPAPER_DIR" >&2
    return 0
  fi
  set_wallpaper "$wallpaper"
  waypaper_config="$HOME/.config/waypaper/config.ini"
  if [ -f "$waypaper_config" ]; then
    ensure_waypaper_post_command "$waypaper_config"
    waypaper_folder="${TARGET_WALLPAPER_DIR/#$HOME/\~}"
    sed -i "s|^folder = .*|folder = $waypaper_folder|" "$waypaper_config"
    sed -i "s|^wallpaper = .*|wallpaper = ${wallpaper/#$HOME/\~}|" "$waypaper_config"
  fi
}

apply_noctalia_wallpaper() {
  local screens
  command -v noctalia-shell >/dev/null 2>&1 || return 0
  stop_video_wallpaper
  screens=$(niri msg outputs 2>/dev/null | grep '^Output ' \
    | sed 's/^Output ".*" (\(.*\))/\1/')

  run_noctalia_wallpaper_job() {
    local first=1 screen shell_path shell_base scripts template_delay=4
    while IFS= read -r screen; do
      [ -n "$screen" ] || continue
      if [ "$first" -eq 1 ]; then
        for _ in $(seq 1 40); do
          noctalia-shell ipc --any-display call wallpaper random "$screen" 2>/dev/null && break
          sleep 0.25
        done
        first=0
      else
        noctalia-shell ipc --any-display call wallpaper random "$screen" 2>/dev/null || true
      fi
    done <<< "$screens"
    [ -z "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ] || template_delay=0
    sleep "$template_delay"
    shell_path=$(readlink -f "$(command -v noctalia-shell)")
    shell_base="${shell_path%/bin/noctalia-shell}"
    scripts="$shell_base/share/noctalia-shell/Scripts/python/src/theming"
    if [ -f "$scripts/template-processor.py" ] && [ -f "$HOME/.config/noctalia/colors.json" ]; then
      cd "$scripts" && python3 template-processor.py \
        --scheme "$HOME/.config/noctalia/colors.json" \
        --config "$HOME/.config/noctalia/user-templates.toml" \
        --mode dark 2>/dev/null || true
    fi
  }

  if [ -n "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ]; then
    (run_noctalia_wallpaper_job) 9>&-
  else
    (run_noctalia_wallpaper_job) 9>&- &
    disown
  fi
}

apply_wallpaper_adapter() {
  if [ "$TARGET_SELF_THEMED" = true ]; then
    apply_noctalia_wallpaper
  else
    apply_static_wallpaper
  fi
}

refresh_pywal() {
  local theme
  command -v wal >/dev/null 2>&1 || return 0
  theme=$(profile_runtime_string "$TARGET_RUNTIME" "$TARGET_VARIANT" pywal)
  [ -n "$theme" ] || theme=base16-nord
  if [ -n "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ]; then
    wal --theme "$theme" -q 2>/dev/null || true
    command -v pywalfox >/dev/null 2>&1 && pywalfox update 2>/dev/null || true
  else
    (
      wal --theme "$theme" -q 2>/dev/null || true
      command -v pywalfox >/dev/null 2>&1 && pywalfox update 2>/dev/null || true
    ) 9>&- &
    disown
  fi
}

restart_swayosd() {
  if [ -n "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ]; then
    systemctl --user restart swayosd 2>/dev/null || true
  else
    (systemctl --user restart swayosd 2>/dev/null || true) 9>&- &
    disown
  fi
}

start_profile_switcher() {
  local switcher_path="$REPO_HOME/configs/quickshell-switcher/shell.qml"
  pgrep -f "quickshell.*quickshell-switcher/shell.qml" >/dev/null 2>&1 && return 0
  if [ -n "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ]; then
    quickshell -p "$switcher_path" 9>&- >/dev/null 2>&1
  else
    quickshell -p "$switcher_path" 9>&- >/dev/null 2>&1 &
    disown
  fi
}

reload_kitty() {
  pkill -USR1 -x kitty 2>/dev/null || true
}

send_profile_notification() {
  notify-send "Desktop Profile" "Switched to $TARGET"
}

run_post_commit_adapter() {
  local name="$1"
  shift
  if [ "${PROFILE_TRANSITION_FAIL_ADAPTER:-}" = "$name" ] || ! "$@"; then
    printf '%s\n' "$name" >> "$ADAPTER_FAILURE_LOG"
  fi
}

dispatch_post_commit_adapters() {
  local summary
  ADAPTER_FAILURE_LOG=$(mktemp "${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/profile-transition-adapters.XXXXXX")
  trap 'rm -f "$ADAPTER_FAILURE_LOG"' EXIT INT TERM HUP

  run_post_commit_adapter wallpaper apply_wallpaper_adapter
  run_post_commit_adapter system-preferences apply_system_preferences
  run_post_commit_adapter profile-switcher start_profile_switcher

  if [ "$MODE" != startup ]; then
    if [ "$TARGET_SELF_THEMED" = true ]; then
      run_post_commit_adapter cava restore_cava_noctalia_theme
    else
      run_post_commit_adapter btop apply_btop_theme "$TARGET_DIR" "$TARGET_VARIANT"
      run_post_commit_adapter tmux apply_tmux_colors "$TARGET_DIR" "$TARGET_VARIANT"
      run_post_commit_adapter hyprlock apply_hyprlock_colors "$TARGET_DIR" "$TARGET_VARIANT"
      run_post_commit_adapter cava apply_cava_colors "$TARGET_DIR" "$TARGET_VARIANT"
      run_post_commit_adapter vicinae apply_vicinae_theme "$TARGET_DIR" "$TARGET_VARIANT"
      run_post_commit_adapter firefox write_firefox_globals "$TARGET_RUNTIME" "$TARGET_VARIANT"
      run_post_commit_adapter swayosd restart_swayosd
      run_post_commit_adapter pywal refresh_pywal
      run_post_commit_adapter kitty reload_kitty
    fi
    run_post_commit_adapter gtk nudge_gtk_reload
    run_post_commit_adapter zed apply_zed_theme "$TARGET_RUNTIME" "$TARGET_VARIANT"
    run_post_commit_adapter vesktop apply_vesktop_theme "$TARGET_RUNTIME" "$TARGET_VARIANT"
    run_post_commit_adapter obsidian apply_obsidian_scheme "$TARGET_RUNTIME" "$TARGET_VARIANT"
    if ! profile_wallpaper_theming "$TARGET"; then
      run_post_commit_adapter spicetify apply_spicetify_theme "$TARGET_RUNTIME" "$TARGET_VARIANT"
    fi
    run_post_commit_adapter notification send_profile_notification
  fi

  if [ -s "$ADAPTER_FAILURE_LOG" ]; then
    summary=$(paste -sd, "$ADAPTER_FAILURE_LOG")
    echo "Warning: post-commit adapters failed: $summary" >&2
  fi
  rm -f "$ADAPTER_FAILURE_LOG"
  trap - EXIT INT TERM HUP
  if [ -n "${PROFILE_TRANSITION_TEST_COMPLETION_FILE:-}" ]; then
    touch "$PROFILE_TRANSITION_TEST_COMPLETION_FILE"
  fi
}

[ $# -ge 1 ] || usage
MODE="$1"
shift

case "$MODE" in
  switch)
    [ $# -eq 1 ] || usage
    REQUESTED_TARGET="$1"
    ;;
  variant)
    [ $# -eq 1 ] || usage
    case "$1" in
      dark | light | toggle) REQUESTED_VARIANT="$1" ;;
      *) usage ;;
    esac
    ;;
  reapply)
    [ $# -eq 0 ] || usage
    ;;
  startup)
    [ $# -le 1 ] || usage
    REQUESTED_TARGET="${1:-}"
    ;;
  *) usage ;;
esac

LOCK_PATH="${PROFILE_TRANSITION_LOCK:-$HOME/.local/state/desktop-profiles/transition.lock}"
mkdir -p "$(dirname "$LOCK_PATH")"
exec 9>"$LOCK_PATH"
flock -n 9 || {
  echo "Error: another profile transition is in progress: $LOCK_PATH" >&2
  exit 75
}

if [ -n "${PROFILE_TRANSITION_TEST_AFTER_LOCK_DIR:-}" ]; then
  touch "$PROFILE_TRANSITION_TEST_AFTER_LOCK_DIR/acquired"
  while [ ! -e "$PROFILE_TRANSITION_TEST_AFTER_LOCK_DIR/release" ]; do
    sleep 0.01
  done
fi

CURRENT=$(read_state "$ACTIVE_FILE" "")
CURRENT_VARIANT=$(read_state "$VARIANT_FILE" "dark")

case "$MODE" in
  switch)
    TARGET="$REQUESTED_TARGET"
    TARGET_VARIANT=$(read_state "$PROFILES_DIR/variant-$TARGET" "dark")
    WRITE_PREFERENCE=1
    ;;
  variant)
    [ -n "$CURRENT" ] || { echo "Error: no active profile." >&2; exit 1; }
    TARGET="$CURRENT"
    if ! has_light_variant "$TARGET"; then
      echo "Profile '$TARGET' has no light variant, nothing to do."
      exit 0
    fi
    case "$REQUESTED_VARIANT" in
      dark | light)
        if [ "$REQUESTED_VARIANT" = "$CURRENT_VARIANT" ]; then
          echo "$TARGET is already $CURRENT_VARIANT."
          exit 0
        fi
        TARGET_VARIANT="$REQUESTED_VARIANT"
        ;;
      toggle)
        if [ "$CURRENT_VARIANT" = dark ]; then
          TARGET_VARIANT=light
        else
          TARGET_VARIANT=dark
        fi
        ;;
    esac
    WRITE_PREFERENCE=1
    ;;
  reapply)
    [ -n "$CURRENT" ] || { echo "Error: no active profile to reapply." >&2; exit 1; }
    TARGET="$CURRENT"
    TARGET_VARIANT="$CURRENT_VARIANT"
    WRITE_PREFERENCE=1
    ;;
  startup)
    TARGET="${REQUESTED_TARGET:-${CURRENT:-noctalia}}"
    if [ -n "$REQUESTED_TARGET" ] && [ "$TARGET" != "$CURRENT" ]; then
      TARGET_VARIANT=$(read_state "$PROFILES_DIR/variant-$TARGET" "dark")
    else
      TARGET_VARIANT="$CURRENT_VARIANT"
    fi
    WRITE_PREFERENCE=0
    if [ ! -d "$PROFILES_DIR/$TARGET" ]; then
      TARGET="noctalia"
      TARGET_VARIANT="dark"
      WRITE_PREFERENCE=1
    fi
    ;;
esac

[ -d "$PROFILES_DIR/$TARGET" ] || { echo "Error: profile '$TARGET' not found." >&2; exit 1; }
profile_manifest_validate "$TARGET" "$TARGET_VARIANT"
if [ "$TARGET_VARIANT" = "light" ] && ! has_light_variant "$TARGET"; then
  echo "Error: profile '$TARGET' has no light variant." >&2
  exit 1
fi

TARGET_DIR="$PROFILES_DIR/$TARGET"
TARGET_RUNTIME="$TARGET_DIR/manifest.json"
TARGET_SELF_THEMED=$(profile_manifest_capability "$TARGET" selfThemed)
TARGET_WALLPAPER_DIR=$(profile_manifest_wallpaper_dir "$TARGET" "$TARGET_VARIANT")

OLD_ACTIVE=$(read_state "$ACTIVE_FILE" "")
OLD_VARIANT=$(read_state "$VARIANT_FILE" "dark")
CURRENT_BAR="noctalia"
if [ -n "$OLD_ACTIVE" ] && [ -f "$PROFILES_DIR/$OLD_ACTIVE/manifest.json" ]; then
  CURRENT_BAR=$(profile_bar "$OLD_ACTIVE")
fi
TARGET_BAR=$(profile_bar "$TARGET")

cleanup_transaction() {
  local status="$1"
  trap - EXIT INT TERM HUP
  rm -rf "$TRANSACTION_DIR" || true
  exit "$status"
}
TRANSACTION_ROOT="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}"
mkdir -p "$TRANSACTION_ROOT"
TRANSACTION_DIR=$(mktemp -d "$TRANSACTION_ROOT/profile-transition.XXXXXX")
trap 'cleanup_transaction $?' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP
chmod 700 "$TRANSACTION_DIR"
SNAPSHOT_COUNT=0
declare -a SNAPSHOT_KINDS=()
declare -a SNAPSHOT_PATHS=()
declare -a SNAPSHOT_PAYLOADS=()
declare -A SNAPSHOT_ENROLLED=()
declare -a STAGED_SOURCES=()
declare -a STAGED_DESTINATIONS=()

snapshot_path() {
  local path="$1" kind payload=""
  [ -z "${SNAPSHOT_ENROLLED[$path]:-}" ] || return 0
  SNAPSHOT_COUNT=$((SNAPSHOT_COUNT + 1))
  if [ -L "$path" ]; then
    kind=symlink
    [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != payload ] || return 23
    IFS= read -r -d '' payload < <(readlink -z -- "$path") || return $?
  elif [ -f "$path" ]; then
    kind=file
    payload="$TRANSACTION_DIR/$SNAPSHOT_COUNT"
    [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != payload ] || return 23
    cp -p -- "$path" "$payload" || return $?
  elif [ ! -e "$path" ]; then
    kind=missing
  else
    echo "Error: cannot snapshot unsupported path: $path" >&2
    return 1
  fi
  [ "${PROFILE_TRANSITION_FAIL_SNAPSHOT:-}" != manifest ] || return 24
  SNAPSHOT_KINDS+=("$kind")
  SNAPSHOT_PATHS+=("$path")
  SNAPSHOT_PAYLOADS+=("$payload")
  SNAPSHOT_ENROLLED["$path"]=1
  if [ -n "${PROFILE_TRANSITION_SIGNAL_DURING_SNAPSHOT:-}" ]; then
    kill -s "$PROFILE_TRANSITION_SIGNAL_DURING_SNAPSHOT" "$$"
  fi
}

snapshot_destination() {
  local path="$1" parent missing
  local -a missing_parents=()
  parent=$(dirname "$path")
  while [ ! -d "$parent" ]; do
    missing_parents+=("$parent")
    [ "$parent" != / ] || break
    parent=$(dirname "$parent")
  done
  for ((missing=${#missing_parents[@]} - 1; missing >= 0; missing--)); do
    parent="${missing_parents[$missing]}"
    [ -z "${SNAPSHOT_ENROLLED[$parent]:-}" ] || continue
    SNAPSHOT_KINDS+=(missing-directory)
    SNAPSHOT_PATHS+=("$parent")
    SNAPSHOT_PAYLOADS+=("")
    SNAPSHOT_ENROLLED["$parent"]=1
  done
  snapshot_or_abort "$path"
}

snapshot_or_abort() {
  local status
  set +e
  snapshot_path "$1"
  status=$?
  set -e
  [ "$status" -ne 0 ] || return 0
  exit "$status"
}

restore_snapshot() {
  local index kind payload path tmp restore_errors=0
  for ((index=${#SNAPSHOT_PATHS[@]} - 1; index >= 0; index--)); do
    kind="${SNAPSHOT_KINDS[$index]}"
    path="${SNAPSHOT_PATHS[$index]}"
    payload="${SNAPSHOT_PAYLOADS[$index]}"
    if [ "${PROFILE_TRANSITION_FAIL_RESTORE_PATH:-}" = "$path" ] \
      && [ "${RESTORE_FAILURE_INJECTED:-0}" -eq 0 ]; then
      RESTORE_FAILURE_INJECTED=1
      echo "rollback: restore $path failed" >&2
      restore_errors=1
      continue
    fi
    case "$kind" in
      missing)
        rm -f -- "$path" || restore_errors=1
        ;;
      missing-directory)
        rmdir -- "$path" 2>/dev/null || restore_errors=1
        ;;
      file)
        mkdir -p "$(dirname "$path")" || { restore_errors=1; continue; }
        tmp=$(mktemp "${path}.XXXXXX") || { restore_errors=1; continue; }
        if ! cp -p -- "$payload" "$tmp" || ! mv -f -- "$tmp" "$path"; then
          rm -f -- "$tmp"
          echo "rollback: restore $path failed" >&2
          restore_errors=1
        fi
        ;;
      symlink)
        if ! link_atomic "$path" "$payload"; then
          echo "rollback: restore $path failed" >&2
          restore_errors=1
        fi
        ;;
    esac
  done
  return "$restore_errors"
}

rollback() {
  local status="$1" rollback_errors=0
  trap - EXIT INT TERM HUP
  set +e
  rollback_try() {
    local label="$1"
    shift
    if ! "$@"; then
      echo "rollback: $label failed" >&2
      rollback_errors=1
    fi
  }
  rollback_try "target bar stop" stop_bar "$TARGET_BAR"
  rollback_try "snapshot restore" restore_snapshot
  rollback_try "Niri reload" niri msg action load-config-file
  if [ -n "$OLD_ACTIVE" ] && [ -f "$PROFILES_DIR/$OLD_ACTIVE/manifest.json" ]; then
    rollback_try "previous bar restart" start_bar "$CURRENT_BAR" "$OLD_ACTIVE" "$OLD_VARIANT"
    rollback_try "previous bar verification" verify_bar "$CURRENT_BAR"
  fi
  rollback_try "snapshot cleanup" rm -rf "$TRANSACTION_DIR"
  [ "$rollback_errors" -eq 0 ] || echo "rollback: one or more recovery operations failed" >&2
  exit "$status"
}

collect_staged_files() {
  local source relative destination
  while IFS= read -r -d '' source; do
    relative=${source#"$TRANSACTION_DIR/home/"}
    destination="$HOME/$relative"
    maybe_fail_stage "$destination"
    STAGED_SOURCES+=("$source")
    STAGED_DESTINATIONS+=("$destination")
  done < <(find "$TRANSACTION_DIR/home" -type f -print0 | sort -z)
}

install_staged_files() {
  local index source destination temporary
  for ((index=0; index<${#STAGED_SOURCES[@]}; index++)); do
    source="${STAGED_SOURCES[$index]}"
    destination="${STAGED_DESTINATIONS[$index]}"
    if [ "${PROFILE_TRANSITION_FAIL_INSTALL_PATH:-}" = "$destination" ]; then
      echo "Error: injected install failure for $destination" >&2
      return "${PROFILE_TRANSITION_FAILURE_STATUS:-1}"
    fi
    mkdir -p "$(dirname "$destination")"
    temporary=$(mktemp "$(dirname "$destination")/.profile-transition.XXXXXX")
    if ! install -m 644 "$source" "$temporary" || ! mv -f "$temporary" "$destination"; then
      rm -f "$temporary"
      return 1
    fi
  done
}

commit_transaction() {
  if [ "$WRITE_PREFERENCE" -eq 1 ]; then
    write_atomic "$ACTIVE_FILE" "$TARGET"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != active ] || return 1
    write_atomic "$VARIANT_FILE" "$TARGET_VARIANT"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != variant ] || return 1
    write_atomic "$PROFILES_DIR/variant-$TARGET" "$TARGET_VARIANT"
    [ "${PROFILE_TRANSITION_FAIL_COMMIT_AFTER:-}" != preference ] || return 1
  fi
  trap 'cleanup_transaction $?' EXIT
  if [ -n "${PROFILE_TRANSITION_SIGNAL_AFTER_COMMIT:-}" ]; then
    kill -s "$PROFILE_TRANSITION_SIGNAL_AFTER_COMMIT" "$$"
  fi
  rm -rf "$TRANSACTION_DIR"
  trap - EXIT INT TERM HUP
}

stage_bar_files "$TARGET_BAR" "$PROFILES_DIR/$TARGET" "$TARGET_VARIANT" "$TRANSACTION_DIR"
stage_profile_core_files "$PROFILES_DIR/$TARGET" "$TARGET_VARIANT" "$TRANSACTION_DIR"
collect_staged_files

if [ "$WRITE_PREFERENCE" -eq 1 ]; then
  snapshot_or_abort "$ACTIVE_FILE"
  snapshot_or_abort "$VARIANT_FILE"
  snapshot_or_abort "$PROFILES_DIR/variant-$TARGET"
fi
snapshot_or_abort "$ACTIVE_LINK"
for destination in "${STAGED_DESTINATIONS[@]}"; do
  snapshot_destination "$destination"
done
if [ -n "${PROFILE_TRANSITION_TEST_FILE_PATH:-}" ]; then
  snapshot_or_abort "$PROFILE_TRANSITION_TEST_FILE_PATH"
fi
if [ -n "${PROFILE_TRANSITION_TEST_SYMLINK_PATH:-}" ]; then
  snapshot_or_abort "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
fi
trap 'rollback $?' EXIT

if [ -n "${PROFILE_TRANSITION_TEST_MUTATE_SNAPSHOTS:-}" ]; then
  printf 'mutated\n' > "$PROFILE_TRANSITION_TEST_FILE_PATH"
  rm -f -- "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
  ln -s -- changed "$PROFILE_TRANSITION_TEST_SYMLINK_PATH"
  exit 29
fi

if [ "$MODE" = reapply ]; then
  stop_all_bars
else
  stop_bar "$CURRENT_BAR"
fi
install_staged_files
NIRI_OVERRIDE=$(profile_manifest_artifact "$TARGET" "$TARGET_VARIANT" niri.default)
if [ "$(read_state "$FOCUS_FILE" "off")" = "on" ] && [ "$TARGET" != "noctalia" ]; then
  NIRI_OVERRIDE=$(profile_manifest_artifact "$TARGET" "$TARGET_VARIANT" niri.focus)
fi
link_atomic "$ACTIVE_LINK" "$NIRI_OVERRIDE"
niri msg action load-config-file >/dev/null 2>&1
start_bar "$TARGET_BAR" "$TARGET" "$TARGET_VARIANT"
verify_bar "$TARGET_BAR"

commit_transaction
flock -u 9
exec 9>&-
if [ -n "${PROFILE_TRANSITION_TEST_SYNC_ASYNC:-}" ]; then
  export PROFILE_TRANSITION_TEST_POST_COMMIT=1
fi
dispatch_post_commit_adapters
exit 0
