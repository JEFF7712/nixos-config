# xhisper configuration — see `xhisper --log` for transcription debug.
# Editable at runtime (this file is symlinked out-of-store).

# Whisper model: tiny, base, small, medium, large-v3 (and *.en variants for
# English-only after `nixos-rebuild switch` picks up the patched derivation).
model-name : small

# Device: auto, cpu, or cuda.
model-device : cuda

# Language: leave empty for auto-detect, or "en" for English-only.
model-language : "en"

transcription-prompt : ""

non-ascii-initial-delay : 0.15
non-ascii-default-delay : 0.025

silence-threshold  : -50
silence-percentage : 95

# AI post-processing via local Ollama. Empty = type raw Whisper output.
# gemma3:4b drifts/paraphrases on long inputs — leave empty unless you want
# light grammar/punctuation fixes on short utterances.
post-process-model     :
post-process-timeout   : 10
post-process-mode      : auto
